<div class="page">
  <div class="page-header">
    <div>
      <h2 class="page-title">Sovg‘alar</h2>
      <p class="page-sub">Sovg‘alar ro‘yxati va boshqaruvi</p>
    </div>
    <a class="btn btn-primary" href="/gifts/new">+ Yangi sovg‘a</a>
  </div>

  {{#if created}}<div class="alert alert-success">Yangi sovg‘a qo‘shildi.</div>{{/if}}
  {{#if updated}}<div class="alert alert-success">Sovg‘a yangilandi.</div>{{/if}}
  {{#if deleted}}<div class="alert alert-warning">Sovg‘a o‘chirildi.</div>{{/if}}

  <div class="toolbar">
    <form method="GET" action="/gifts" class="search">
      <input class="input" type="text" name="q" value="{{data.q}}" placeholder="Nomi bo‘yicha qidirish…" />
      <button class="btn btn-primary" type="submit">Qidirish</button>
      {{#if data.q}}<a class="btn btn-ghost" href="/gifts">Tozalash</a>{{/if}}
    </form>
  </div>

  <div class="card">
    {{#if data.items.length}}
      <div class="grid-cards">
        {{#each data.items}}
          <div class="product-card">
            <div class="product-thumb">
              <img src="{{image}}" alt="{{title}}" loading="lazy" onerror="this.classList.add('broken'); this.src='/img/placeholder.svg';" />
            </div>
            <div class="product-body">
              <h3 class="product-title">{{title}}</h3>
              <div class="product-price">{{formatPrice price}} so‘m</div>
            </div>
            <div class="product-actions">
              <a class="btn btn-sm btn-ghost" href="/gifts/{{id}}/edit">Tahrirlash</a>
              <form method="POST" action="/gifts/{{id}}/delete" data-confirm="Sovg‘ani o‘chirishni tasdiqlaysizmi?">
                <button type="submit" class="btn btn-sm btn-danger">O‘chirish</button>
              </form>
            </div>
          </div>
        {{/each}}
      </div>
      {{> pagination}}
    {{else}}
      <div class="empty">
        <div class="empty-title">Sovg‘a topilmadi</div>
        <div class="empty-sub">{{#if data.q}}Qidiruvga mos sovg‘a yo‘q.{{else}}Birinchi sovg‘ani qo‘shing.{{/if}}</div>
        <a class="btn btn-primary" href="/gifts/new">+ Sovg‘a qo‘shish</a>
      </div>
    {{/if}}
  </div>
</div>
