<div class="page page-narrow">
  <div class="page-header">
    <div>
      <h2 class="page-title">Xabar yuborish</h2>
      <p class="page-sub">Telegram orqali foydalanuvchilarga xabar jo'natish</p>
    </div>
  </div>

  {{#if result}}
  <div class="alert alert-success">
    ✅ Yuborildi: <strong>{{result.sent}}</strong> / {{result.total}}
    {{#if (gt result.failed 0)}} • Xato: <strong>{{result.failed}}</strong>{{/if}}
  </div>
  {{/if}}
  {{#if error}}<div class="alert alert-error">{{error}}</div>{{/if}}

  <div class="card">
    <div class="card-header">
      <h3 class="card-title">📣 Barcha foydalanuvchilarga</h3>
    </div>
    <form method="POST" action="/broadcast/all" class="form"
          data-confirm="Xabar barcha foydalanuvchilarga yuboriladi. Tasdiqlaysizmi?">
      <div class="field">
        <span class="field-label">Xabar matni</span>
        <textarea class="input" name="message" rows="5"
                  placeholder="Xabar matnini kiriting...&#10;HTML teglari ishlaydi: &lt;b&gt;qalin&lt;/b&gt;, &lt;i&gt;kursiv&lt;/i&gt;, &lt;a href='...'&gt;havola&lt;/a&gt;"
                  required></textarea>
        <span class="field-hint">HTML teglari ishlaydi: &lt;b&gt;, &lt;i&gt;, &lt;a href=""&gt;, &lt;code&gt;</span>
      </div>
      <div class="form-actions">
        <button class="btn btn-primary" type="submit">📤 Yuborish</button>
      </div>
    </form>
  </div>
</div>
