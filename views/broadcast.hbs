<div class="page page-narrow">
  <div class="page-header">
    <div>
      <h2 class="page-title">{{t 'nav_broadcast'}}</h2>
      <p class="page-sub">{{t 'broadcast_sub'}}</p>
    </div>
  </div>

  {{#if result}}
  <div class="alert alert-success">
    ✅ {{t 'broadcast_sent'}}: <strong>{{result.sent}}</strong> / {{result.total}}
    {{#if (gt result.failed 0)}} • {{t 'broadcast_error_count'}}: <strong>{{result.failed}}</strong>{{/if}}
  </div>
  {{/if}}
  {{#if error}}<div class="alert alert-error">{{error}}</div>{{/if}}

  <div class="card">
    <div class="card-header">
      <h3 class="card-title">{{t 'broadcast_all'}}</h3>
    </div>
    <form method="POST" action="/broadcast/all" class="form"
          data-confirm="{{t 'broadcast_confirm'}}">
      <div class="field">
        <span class="field-label">{{t 'message_text'}}</span>
        <textarea class="input" name="message" rows="5"
                  placeholder="{{t 'broadcast_ph'}}"
                  required></textarea>
        <span class="field-hint">{{t 'broadcast_hint'}}</span>
      </div>
      <div class="form-actions">
        <button class="btn btn-primary" type="submit">{{t 'send'}}</button>
      </div>
    </form>
  </div>
</div>
