<div class="page">
  <div class="page-header">
    <div>
      <h2 class="page-title">{{t 'nav_products'}}</h2>
      <p class="page-sub">{{t 'products_sub'}}</p>
    </div>
    <a class="btn btn-primary" href="/products/new">{{t 'new_product'}}</a>
  </div>

  {{#if created}}<div class="alert alert-success">{{t 'product_created'}}</div>{{/if}}
  {{#if updated}}<div class="alert alert-success">{{t 'product_updated'}}</div>{{/if}}
  {{#if deleted}}<div class="alert alert-warning">{{t 'product_deleted'}}</div>{{/if}}

  <div class="toolbar">
    <form method="GET" action="/products" class="search">
      <input class="input" type="text" name="q" value="{{data.q}}" placeholder="{{t 'products_search_ph'}}" />
      <button class="btn btn-primary" type="submit">{{t 'search'}}</button>
      {{#if data.q}}<a class="btn btn-ghost" href="/products">{{t 'clear'}}</a>{{/if}}
    </form>
  </div>

  <div class="card">
    {{#if data.items.length}}
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th class="num">#</th>
              <th>{{t 'image'}}</th>
              <th>{{t 'name'}}</th>
              <th>{{t 'col_bonus'}}</th>
              <th>{{t 'col_links'}}</th>
              <th>{{t 'col_added'}}</th>
              <th class="actions">{{t 'actions'}}</th>
            </tr>
          </thead>
          <tbody>
            {{#each data.items}}
              <tr>
                <td class="num">{{inc @index}}</td>
                <td>
                  {{#if image}}
                    <img src="{{image}}" alt="{{title}}" style="width:40px;height:40px;object-fit:cover;border-radius:4px;" onerror="this.src='/img/placeholder.svg';" />
                  {{else}}
                    <img src="/img/placeholder.svg" alt="—" style="width:40px;height:40px;opacity:.4;" />
                  {{/if}}
                </td>
                <td>
                  <strong>{{title}}</strong>
                  {{#if requireChannel}}<span class="status-badge status-pending" style="font-size:11px;margin-left:4px">{{t 'require_channel_badge'}}</span>{{/if}}
                </td>
                <td><span class="bonus-pill">+{{formatPrice bonus}}</span></td>
                <td>
                  <div style="display:flex;flex-direction:column;gap:4px">
                    <a class="social-link uzum-link" href="{{uzum_url}}" target="_blank" rel="noopener">
                      🍇 Uzum
                    </a>
                    {{#if telegramChannel}}
                    <a class="social-link tg-link" href="{{telegramChannel}}" target="_blank" rel="noopener">
                      ✈️ Telegram
                    </a>
                    {{/if}}
                    {{#if instagram}}
                    <a class="social-link ig-link" href="{{instagram}}" target="_blank" rel="noopener">
                      📸 Instagram
                    </a>
                    {{/if}}
                  </div>
                </td>
                <td class="muted">{{formatDate createdAt}}</td>
                <td class="actions">
                  <a class="btn btn-sm btn-ghost" href="/products/{{id}}/edit">{{t 'edit'}}</a>
                  <form method="POST" action="/products/{{id}}/delete" data-confirm="{{t 'product_delete_confirm'}}">
                    <button type="submit" class="btn btn-sm btn-danger">{{t 'delete'}}</button>
                  </form>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
      {{> pagination}}
    {{else}}
      <div class="empty">
        <div class="empty-title">{{t 'products_empty'}}</div>
        <div class="empty-sub">{{#if data.q}}{{t 'products_empty_search'}}{{else}}{{t 'products_empty_none'}}{{/if}}</div>
        <a class="btn btn-primary" href="/products/new">{{t 'add_product'}}</a>
      </div>
    {{/if}}
  </div>
</div>
