<div class="page">
  <div class="page-header">
    <div>
      <h2 class="page-title">{{t 'nav_users'}}</h2>
      <p class="page-sub">{{t 'users_sub'}}</p>
    </div>
  </div>

  {{#if updated}}
    <div class="alert alert-success">{{t 'users_updated'}}</div>
  {{/if}}

  <div class="toolbar">
    <form method="GET" action="/users" class="search">
      <input class="input" type="text" name="q" value="{{data.q}}" placeholder="{{t 'users_search_ph'}}" />
      <button class="btn btn-primary" type="submit">{{t 'search'}}</button>
      {{#if data.q}}
        <a class="btn btn-ghost" href="/users">{{t 'clear'}}</a>
      {{/if}}
    </form>
    <a class="btn btn-ghost" href="/users/export{{#if data.q}}?q={{data.q}}{{/if}}">{{t 'excel'}}</a>
  </div>

  <div class="card">
    {{#if data.items.length}}
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th class="num">#</th>
              <th>{{t 'col_firstname'}}</th>
              <th>{{t 'col_lastname'}}</th>
              <th>{{t 'col_phone'}}</th>
              <th>{{t 'col_username'}}</th>
              <th>{{t 'date'}}</th>
              <th class="actions">{{t 'actions'}}</th>
            </tr>
          </thead>
          <tbody>
            {{#each data.items}}
              <tr>
                <td class="num">{{inc @index}}</td>
                <td>{{#if firstName}}{{firstName}}{{else}}<span class="muted">—</span>{{/if}}</td>
                <td>{{#if lastName}}{{lastName}}{{else}}<span class="muted">—</span>{{/if}}</td>
                <td>{{#if phone}}<code>{{phone}}</code>{{else}}<span class="muted">—</span>{{/if}}</td>
                <td>{{#if username}}@{{username}}{{else}}<span class="muted">—</span>{{/if}}</td>
                <td class="muted">{{formatDate createdAt}}</td>
                <td class="actions">
                  <a class="btn btn-sm btn-ghost" href="/users/{{id}}">{{t 'profile_btn'}}</a>
                  <a class="btn btn-sm btn-ghost" href="/users/{{id}}/edit">{{t 'edit'}}</a>
                  <form method="POST" action="/users/{{id}}/delete" style="display:inline"
                        data-confirm="{{t 'users_delete_confirm'}}">
                    <button type="submit" class="btn btn-sm btn-danger">{{t 'delete'}}</button>
                  </form>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
      {{> pagination}}
    {{else}}
      <div class="empty">
        <div class="empty-title">{{t 'users_empty'}}</div>
        <div class="empty-sub">{{#if data.q}}{{t 'users_empty_search'}}{{else}}{{t 'users_empty_none'}}{{/if}}</div>
      </div>
    {{/if}}
  </div>
</div>
