<aside class="sidebar">
  <div class="brand">
    <span class="brand-logo">
      {{#if adminProfile.avatar}}
        <img src="{{adminProfile.avatar}}" alt="avatar" style="width:34px;height:34px;border-radius:8px;object-fit:cover;">
      {{else}}
        A
      {{/if}}
    </span>
    <span class="brand-text">{{t 'brand'}}</span>
  </div>
  <nav class="nav">
    <a href="/" class="nav-item {{#if (eq active 'dashboard')}}is-active{{/if}}">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
      <span>{{t 'nav_dashboard'}}</span>
    </a>
    <a href="/users" class="nav-item {{#if (eq active 'users')}}is-active{{/if}}">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      <span>{{t 'nav_users'}}</span>
    </a>
    <a href="/products" class="nav-item {{#if (eq active 'products')}}is-active{{/if}}">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
      <span>{{t 'nav_products'}}</span>
    </a>
    <a href="/gifts" class="nav-item {{#if (eq active 'gifts')}}is-active{{/if}}">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
      <span>{{t 'nav_gifts'}}</span>
    </a>
    <a href="/confirmations" class="nav-item {{#if (eq active 'confirmations')}}is-active{{/if}}">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
      <span>{{t 'nav_confirmations'}}</span>
      {{#if pendingConfirmations}}<span class="nav-badge">{{pendingConfirmations}}</span>{{/if}}
    </a>
    <a href="/gift-orders" class="nav-item {{#if (eq active 'gift-orders')}}is-active{{/if}}">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
      <span>{{t 'nav_gift_orders'}}</span>
      <span class="nav-badge" id="giftNavBadge" style="{{#unless pendingGifts}}display:none{{/unless}}">{{pendingGifts}}</span>
    </a>
    <a href="/broadcast" class="nav-item {{#if (eq active 'broadcast')}}is-active{{/if}}">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.49 12 19.79 19.79 0 0 1 1.21 3.39 2 2 0 0 1 3.18 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16.92z"/></svg>
      <span>{{t 'nav_broadcast'}}</span>
    </a>
    <a href="/admin/codes" class="nav-item {{#if (eq active 'codes')}}is-active{{/if}}">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      <span>Kodlar</span>
    </a>
    <a href="/admin/profile" class="nav-item {{#if (eq active 'admin-profile')}}is-active{{/if}}">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
      <span>{{t 'nav_profile'}}</span>
    </a>
  </nav>
  <div class="sidebar-footer">
    <a class="logout" href="/logout" data-confirm="{{t 'logout_confirm'}}">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      <span>{{t 'logout'}}</span>
    </a>
  </div>
</aside>
