<!doctype html>
<html lang="uz">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{title}} • Admin</title>
    <link rel="icon" type="image/svg+xml" href="/img/favicon.svg" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <!-- Mobil overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

    <div class="app">
      {{> sidebar}}
      <main class="main">
        {{> topbar}}
        <section class="content">
          {{{body}}}
        </section>
      </main>
    </div>
    <!-- Rasm to'liq ekran (lightbox) -->
    <div class="lightbox" id="lightbox" onclick="closeLightbox()">
      <span class="lightbox-close" aria-label="Yopish">&times;</span>
      <img id="lightboxImg" src="" alt="" onclick="event.stopPropagation()">
    </div>

    <script src="/js/app.js" defer></script>
    <script>
      function openLightbox(src) {
        if (!src) return;
        document.getElementById('lightboxImg').src = src;
        document.getElementById('lightbox').classList.add('active');
        document.body.style.overflow = 'hidden';
      }
      function closeLightbox() {
        document.getElementById('lightbox').classList.remove('active');
        document.getElementById('lightboxImg').src = '';
        document.body.style.overflow = '';
      }
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeLightbox();
      });

      // Bildirishnomalar — har 20s avtomatik yangilanadi (sahifa qayta yuklanmaydi)
      (function () {
        var bell = document.getElementById('topbarBell');
        var badge = document.getElementById('bellBadge');
        var giftBadge = document.getElementById('giftNavBadge');
        var lastTotal = -1;
        var baseTitle = document.title.replace(/^\(\d+\)\s*/, '');

        async function fetchCount(url, key) {
          try {
            var r = await fetch(url, { headers: { 'Accept': 'application/json' } });
            if (!r.ok) return 0;
            var d = await r.json();
            return d[key] || 0;
          } catch (e) { return 0; }
        }

        function setBadge(el, n, bellEl) {
          if (!el) return;
          if (n > 0) { el.textContent = n; el.style.display = ''; if (bellEl) bellEl.classList.add('has-pending'); }
          else { el.style.display = 'none'; if (bellEl) bellEl.classList.remove('has-pending'); }
        }

        async function check() {
          var [pending, gifts] = await Promise.all([
            fetchCount('/confirmations/count', 'pending'),
            fetchCount('/gift-orders/count', 'pending'),
          ]);
          setBadge(badge, pending, bell);
          setBadge(giftBadge, gifts, null);
          var total = pending + gifts;
          if (lastTotal !== -1 && total > lastTotal) {
            document.title = '(' + total + ') ' + baseTitle;
          } else if (total === 0) {
            document.title = baseTitle;
          }
          lastTotal = total;
        }
        setInterval(check, 20000);
      })();

      function openSidebar() {
        document.querySelector('.sidebar').classList.add('sidebar--open');
        document.getElementById('sidebarOverlay').classList.add('active');
        document.body.style.overflow = 'hidden';
      }
      function closeSidebar() {
        document.querySelector('.sidebar').classList.remove('sidebar--open');
        document.getElementById('sidebarOverlay').classList.remove('active');
        document.body.style.overflow = '';
      }
    </script>
  </body>
</html>
