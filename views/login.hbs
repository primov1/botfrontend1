<!doctype html>
<html lang="uz">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{t 'login_title'}} • Admin</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="login-body">
    <div class="login-wrap">
      <div class="login-card">
        <div class="login-lang" style="display:flex;justify-content:center;gap:10px;margin-bottom:14px">
          <a href="/lang/uz" title="O‘zbekcha" style="text-decoration:none;font-size:22px;opacity:{{#if (eq lang 'uz')}}1{{else}}0.4{{/if}}">🇺🇿</a>
          <a href="/lang/ru" title="Русский" style="text-decoration:none;font-size:22px;opacity:{{#if (eq lang 'ru')}}1{{else}}0.4{{/if}}">🇷🇺</a>
          <a href="/lang/en" title="English" style="text-decoration:none;font-size:22px;opacity:{{#if (eq lang 'en')}}1{{else}}0.4{{/if}}">🇬🇧</a>
        </div>
        <div class="login-logo">A</div>
        <h1 class="login-title">{{t 'login_title'}}</h1>
        <p class="login-sub">{{t 'login_sub'}}</p>

        {{#if error}}
          <div class="alert alert-error">{{t error}}</div>
        {{/if}}

        <form method="POST" action="/login" class="login-form" autocomplete="off">
          <label class="field">
            <span class="field-label">{{t 'login_label'}}</span>
            <input class="input" type="text" name="login" value="{{login}}" placeholder="admin" required autofocus />
          </label>
          <label class="field">
            <span class="field-label">{{t 'password_label'}}</span>
            <input class="input" type="password" name="password" placeholder="••••••••" required />
          </label>
          {{#if needPhone}}
          <label class="field">
            <span class="field-label">{{t 'phone_label'}}</span>
            <input class="input" type="tel" name="phone" value="{{phone}}"
                   placeholder="+998 90 123 45 67" required />
            <span class="field-hint">{{t 'phone_hint'}}</span>
          </label>
          {{/if}}
          <button class="btn btn-primary btn-block" type="submit">{{t 'login_btn'}}</button>
        </form>
      </div>
    </div>
  </body>
</html>
