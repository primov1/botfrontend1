<!doctype html>
<html lang="uz">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{title}} • Admin</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="login-body">
    <div class="login-wrap">
      <div class="login-card">
        <div class="login-logo">A</div>
        <h1 class="login-title">Admin panelga kirish</h1>
        <p class="login-sub">Davom etish uchun login va parolni kiriting</p>

        {{#if error}}
          <div class="alert alert-error">{{error}}</div>
        {{/if}}

        <form method="POST" action="/login" class="login-form" autocomplete="off">
          <label class="field">
            <span class="field-label">Login</span>
            <input class="input" type="text" name="login" value="{{login}}" placeholder="admin" required autofocus />
          </label>
          <label class="field">
            <span class="field-label">Parol</span>
            <input class="input" type="password" name="password" placeholder="••••••••" required />
          </label>
          <button class="btn btn-primary btn-block" type="submit">Kirish</button>
        </form>
      </div>
    </div>
  </body>
</html>
