<div class="page">
  <div class="page-header">
    <div>
      <h2 class="page-title">🎫 Kodlar</h2>
      <p class="page-sub">Mahsulot kodlari — generatsiya, CSV va chop etish</p>
    </div>
  </div>

  {{#if generated}}<div class="alert alert-success">✅ {{generated}} ta kod yaratildi.</div>{{/if}}
  {{#if error}}<div class="alert alert-error">❌ {{error}}</div>{{/if}}

  {{! === PDF yaratish (xprinter) === }}
  <div class="card" style="margin-bottom:16px">
    <div class="card-header"><h3 class="card-title">🖨 Stiker PDF yaratish</h3></div>
    <form method="POST" action="/admin/print/generate-pdf" class="form">
      <label class="field" style="max-width:220px">
        <span class="field-label">Nechta? <span class="req">*</span></span>
        <input class="input" type="number" name="count" min="1" max="10000" step="1"
               value="100" required placeholder="masalan: 100">
      </label>
      <label class="field">
        <span class="field-label">Stiker matni</span>
        <input class="input" type="text" name="text" maxlength="200" value="{{stickerText}}"
               placeholder="Sotib oling va bonuslarga ega bo'ling!">
      </label>
      <label class="field">
        <span class="field-label">Mahsulot <span class="field-hint" style="font-weight:400">(ixtiyoriy — bonus uchun)</span></span>
        <select class="input" name="product_id" style="max-width:320px">
          <option value="">— mahsulotsiz (oddiy) —</option>
          {{#each products}}
            <option value="{{id}}">{{title}} (+{{bonus}})</option>
          {{/each}}
        </select>
      </label>
      <div class="form-actions">
        <button class="btn btn-primary" type="submit">🖨 PDF yaratish va yuklab olish</button>
      </div>
    </form>
    <p class="field-hint" style="padding:6px 4px 0">
      Kod: <code>AXZ78RT</code> (7 talik). Har stiker: 1 QR (?start=KOD) + kod.
      PDF har yorliq alohida sahifa — xprinterda chop eting.
    </p>
  </div>

</div>
