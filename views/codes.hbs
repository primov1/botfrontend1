<div class="page">
  <div class="page-header">
    <div>
      <h2 class="page-title">🎫 Kodlar</h2>
      <p class="page-sub">Mahsulot kodlari — generatsiya, CSV va chop etish</p>
    </div>
  </div>

  {{#if generated}}<div class="alert alert-success">✅ {{generated}} ta kod yaratildi.</div>{{/if}}
  {{#if filter.error}}<div class="alert alert-error">❌ {{filter.error}}</div>{{/if}}

  {{! === Generatsiya === }}
  <div class="card" style="margin-bottom:16px">
    <div class="card-header"><h3 class="card-title">⚙️ Kod yaratish</h3></div>
    <form method="POST" action="/admin/codes/generate" class="form"
          style="flex-direction:row;align-items:flex-end;gap:12px;flex-wrap:wrap"
          data-confirm="Tanlangan miqdorda kod yaratilsinmi?">
      <label class="field" style="margin:0;min-width:220px">
        <span class="field-label">Mahsulot <span class="req">*</span></span>
        <select class="input" name="product_id" required>
          <option value="">— tanlang —</option>
          {{#each products}}
            <option value="{{id}}">{{title}} (P{{id}})</option>
          {{/each}}
        </select>
      </label>
      <label class="field" style="margin:0;max-width:160px">
        <span class="field-label">Miqdor <span class="req">*</span></span>
        <select class="input" name="count" required>
          <option value="500">500</option>
          <option value="1000">1000</option>
          <option value="1500">1500</option>
          <option value="2000">2000</option>
        </select>
      </label>
      <button class="btn btn-primary" type="submit">➕ Yaratish</button>
    </form>
  </div>

  {{! === Filtrlar === }}
  <div class="toolbar">
    <form method="GET" action="/admin/codes" class="search" style="flex-wrap:wrap;gap:8px">
      <select class="input" name="product_id" style="max-width:200px" onchange="this.form.submit()">
        <option value="">Barcha mahsulotlar</option>
        {{#each products}}
          <option value="{{id}}" {{#if (eq ../filter.productId id)}}selected{{/if}}>{{title}}</option>
        {{/each}}
      </select>
      <select class="input" name="is_used" style="max-width:160px" onchange="this.form.submit()">
        <option value="">Holat: barchasi</option>
        <option value="0" {{#if (eq filter.isUsed '0')}}selected{{/if}}>Ishlatilmagan</option>
        <option value="1" {{#if (eq filter.isUsed '1')}}selected{{/if}}>Ishlatilgan</option>
      </select>
      <select class="input" name="expired" style="max-width:160px" onchange="this.form.submit()">
        <option value="">Muddat: barchasi</option>
        <option value="0" {{#if (eq filter.expired '0')}}selected{{/if}}>Amal qiladi</option>
        <option value="1" {{#if (eq filter.expired '1')}}selected{{/if}}>Muddati o'tgan</option>
      </select>
    </form>
    {{#if filter.productId}}
      <div style="display:flex;gap:8px">
        <a class="btn btn-ghost" href="/admin/codes/export/{{filter.productId}}">⬇ CSV</a>
        <a class="btn btn-ghost" href="/admin/print/{{filter.productId}}" target="_blank">🖨 Chop etish</a>
      </div>
    {{/if}}
  </div>

  {{! === Ro'yxat === }}
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">Kodlar ro'yxati</h3>
      <span class="badge">{{data.total}}</span>
    </div>
    {{#if data.items.length}}
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th class="num">#</th>
              <th>Kod</th>
              <th>Mahsulot</th>
              <th>Ball</th>
              <th>Holat</th>
              <th>Yaratilgan</th>
              <th>Muddat</th>
              <th class="actions">Amallar</th>
            </tr>
          </thead>
          <tbody>
            {{#each data.items}}
              <tr>
                <td class="num">{{inc @index}}</td>
                <td><code>{{code}}</code></td>
                <td>{{lookup ../productMap productId}}</td>
                <td><span class="bonus-pill">+{{points}}</span></td>
                <td>
                  {{#if isUsed}}<span class="status-badge status-rejected">Ishlatilgan</span>
                  {{else}}<span class="status-badge status-approved">Yangi</span>{{/if}}
                </td>
                <td class="muted">{{formatDate createdAt}}</td>
                <td class="muted">{{formatDate expiresAt}}</td>
                <td class="actions">
                  <a class="btn btn-sm btn-ghost" href="/admin/print/single/{{id}}" target="_blank" title="Stiker">🖨</a>
                  {{#unless isUsed}}
                    <form method="POST" action="/admin/codes/{{id}}/delete?back=/admin/codes{{#if ../filter.productId}}?product_id={{../filter.productId}}{{/if}}" style="display:inline"
                          data-confirm="Kodni o'chirishni tasdiqlaysizmi?">
                      <button type="submit" class="btn btn-sm btn-ghost btn-icon-danger">🗑</button>
                    </form>
                  {{/unless}}
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>

      {{#if (ne data.totalPages 1)}}
        <div class="pagination">
          <span class="pagination-info">Jami: <b>{{data.total}}</b></span>
          <div class="pagination-controls">
            <a class="page-link {{#if (eq data.page 1)}}is-disabled{{/if}}" href="?product_id={{filter.productId}}&page={{dec data.page}}">←</a>
            <span class="page-link is-current">{{data.page}} / {{data.totalPages}}</span>
            <a class="page-link {{#if (eq data.page data.totalPages)}}is-disabled{{/if}}" href="?product_id={{filter.productId}}&page={{inc data.page}}">→</a>
          </div>
        </div>
      {{/if}}
    {{else}}
      <div class="empty"><div class="empty-title">Kod topilmadi</div><div class="empty-sub">Yuqoridan kod yarating.</div></div>
    {{/if}}
  </div>
</div>
