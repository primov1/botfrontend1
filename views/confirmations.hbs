<div class="page">
  <div class="page-header">
    <div>
      <h2 class="page-title">{{t 'nav_confirmations'}}</h2>
      <p class="page-sub">{{t 'conf_sub'}}</p>
    </div>
  </div>

  {{#if approved}}<div class="alert alert-success">{{t 'conf_approved_alert'}}</div>{{/if}}
  {{#if rejected}}<div class="alert alert-warning">{{t 'conf_rejected_alert'}}</div>{{/if}}

  <div class="tabs">
    <a class="tab {{#if (eq data.status 'pending')}}is-active{{/if}}" href="/confirmations?status=pending">
      {{t 'tab_pending'}} <span class="tab-count">{{data.counts.pending}}</span>
    </a>
    <a class="tab {{#if (eq data.status 'approved')}}is-active{{/if}}" href="/confirmations?status=approved">
      {{t 'tab_approved'}} <span class="tab-count">{{data.counts.approved}}</span>
    </a>
    <a class="tab {{#if (eq data.status 'rejected')}}is-active{{/if}}" href="/confirmations?status=rejected">
      {{t 'tab_rejected'}} <span class="tab-count">{{data.counts.rejected}}</span>
    </a>
    <a class="tab {{#if (eq data.status 'all')}}is-active{{/if}}" href="/confirmations?status=all">
      {{t 'tab_all'}} <span class="tab-count">{{data.counts.total}}</span>
    </a>
  </div>

  <div class="card">
    {{#if data.items.length}}
      <div class="confirm-list">
        {{#each data.items}}
          <div class="confirm-item">
            <div class="confirm-proof" {{#if proofImage}}onclick="openLightbox('{{proofImage}}')" style="cursor:zoom-in"{{/if}}>
              {{#if proofImage}}
                <img src="{{proofImage}}" alt="proof" onerror="this.src='/img/placeholder.svg';" />
              {{else}}
                <span class="confirm-proof-empty">{{t 'no_image'}}</span>
              {{/if}}
            </div>

            <div class="confirm-main">
              <div class="confirm-row">
                {{#if user}}
                  <a class="confirm-user" href="/users/{{user.id}}">
                    {{#if user.firstName}}{{user.firstName}} {{/if}}{{#if user.lastName}}{{user.lastName}}{{/if}}
                    {{#unless user.firstName}}{{#unless user.lastName}}{{t 'user_word'}}{{/unless}}{{/unless}}
                  </a>
                  {{#if user.phone}}<code>{{user.phone}}</code>{{/if}}
                {{else}}
                  <span class="muted">{{t 'user_deleted_label'}}</span>
                {{/if}}
                {{#if (eq status 'pending')}}<span class="status-badge status-pending">{{t 'tab_pending'}}</span>{{/if}}
                {{#if (eq status 'approved')}}<span class="status-badge status-approved">{{t 'tab_approved'}}</span>{{/if}}
                {{#if (eq status 'rejected')}}<span class="status-badge status-rejected">{{t 'tab_rejected'}}</span>{{/if}}
              </div>

              <div class="confirm-row">
                {{#if product}}
                  <strong>{{product.title}}</strong>
                  {{#if product.uzum_url}}
                    <a class="product-link" href="{{product.uzum_url}}" target="_blank" rel="noopener">Uzum</a>
                  {{/if}}
                {{else}}
                  <span class="muted">{{t 'product_deleted_label'}}</span>
                {{/if}}
                <span class="bonus-pill">+{{formatPrice bonus}} {{t 'bonus_word'}}</span>
              </div>

              {{#if reviewComment}}
                <div class="confirm-comment">“{{reviewComment}}”</div>
              {{/if}}

              <div class="confirm-meta muted">
                {{t 'sent_label'}}: {{formatDate createdAt}}
                {{#if reviewSubmitted}} • <span class="confirm-flag">{{t 'purchase_marked'}}</span>{{/if}}
                {{#if reviewedAt}} • {{t 'reviewed_label'}}: {{formatDate reviewedAt}}{{/if}}
              </div>
              {{#if reviewNote}}<div class="confirm-meta muted">{{t 'admin_note'}}: {{reviewNote}}</div>{{/if}}
            </div>

            {{#if (eq status 'pending')}}
              <div class="confirm-actions">
                <form method="POST" action="/confirmations/{{id}}/approve?status={{../data.status}}">
                  <button type="submit" class="btn btn-sm btn-success btn-block">{{t 'approve_btn'}}</button>
                </form>
                <form method="POST" action="/confirmations/{{id}}/reject?status={{../data.status}}"
                      data-confirm="{{t 'reject_confirm'}}">
                  <textarea class="input" name="note" rows="2" placeholder="{{t 'reject_reason_ph'}}" style="resize:vertical;font-size:0.85rem;margin-bottom:6px;"></textarea>
                  <button type="submit" class="btn btn-sm btn-danger btn-block">{{t 'reject_btn'}}</button>
                </form>
              </div>
            {{/if}}
          </div>
        {{/each}}
      </div>

      {{#if (ne data.totalPages 1)}}
        <div class="pagination">
          <span class="pagination-info">{{t 'total_label'}}: <b>{{data.total}}</b></span>
          <div class="pagination-controls">
            <a class="page-link {{#unless data.hasPrev}}is-disabled{{/unless}}"
               href="?status={{data.status}}&page={{data.prevPage}}&limit={{data.limit}}">←</a>
            <span class="page-link is-current">{{data.page}} / {{data.totalPages}}</span>
            <a class="page-link {{#unless data.hasNext}}is-disabled{{/unless}}"
               href="?status={{data.status}}&page={{data.nextPage}}&limit={{data.limit}}">→</a>
          </div>
        </div>
      {{/if}}
    {{else}}
      <div class="empty">
        <div class="empty-title">{{t 'conf_empty'}}</div>
        <div class="empty-sub">
          {{#if (eq data.status 'pending')}}{{t 'conf_empty_pending'}}{{else}}{{t 'conf_empty_other'}}{{/if}}
        </div>
      </div>
    {{/if}}
  </div>
</div>
