<div class="page">
  <div class="page-header">
    <div>
      <h2 class="page-title">{{t 'nav_admins'}}</h2>
      <p class="page-sub">{{t 'admins_sub'}}</p>
    </div>
  </div>

  {{#if (eq query.created "1")}}<div class="alert alert-success">{{t 'admin_created'}}</div>{{/if}}
  {{#if (eq query.deleted "1")}}<div class="alert alert-warning">{{t 'admin_deleted'}}</div>{{/if}}
  {{#if (eq query.limit_ok "1")}}<div class="alert alert-success">{{t 'admin_limit_updated'}}</div>{{/if}}
  {{#if query.error}}<div class="alert alert-error">❌ {{query.error}}</div>{{/if}}

  {{! === Limit === }}
  <div class="card" style="margin-bottom:16px">
    <div class="card-header"><h3 class="card-title">{{t 'max_admins_title'}}</h3></div>
    <form method="POST" action="/admins/limit" class="form" style="flex-direction:row;align-items:flex-end;gap:12px;flex-wrap:wrap">
      <label class="field" style="margin:0">
        <span class="field-label">{{t 'limit_label'}}</span>
        <input class="input" type="number" name="max" value="{{max}}" min="{{count}}" step="1"
               required style="max-width:140px">
      </label>
      <button class="btn btn-primary" type="submit">💾 {{t 'save'}}</button>
      <span class="field-hint" style="margin-bottom:10px">{{t 'now_label'}}: {{count}} / {{max}}</span>
    </form>
  </div>

  {{! === Yangi admin === }}
  <div class="card" style="margin-bottom:16px">
    <div class="card-header">
      <h3 class="card-title">{{t 'new_admin_title'}}</h3>
      {{#if limitReached}}<span class="badge badge-muted">{{t 'limit_full_badge'}}</span>{{/if}}
    </div>
    {{#if limitReached}}
      <p class="field-hint" style="padding:0 4px">{{t 'limit_full_text'}}</p>
    {{else}}
      <form method="POST" action="/admins/new" class="form">
        <div class="grid-2">
          <label class="field">
            <span class="field-label">{{t 'login_label'}} <span class="req">*</span></span>
            <input class="input" type="text" name="login" required minlength="3" autocomplete="off"
                   placeholder="{{t 'login_ph_3'}}">
          </label>
          <label class="field">
            <span class="field-label">{{t 'name_field'}}</span>
            <input class="input" type="text" name="name" placeholder="{{t 'name_ph'}}">
          </label>
        </div>
        <div class="grid-2">
          <label class="field">
            <span class="field-label">{{t 'password_field'}} <span class="req">*</span></span>
            <input class="input" type="password" name="password" required minlength="6"
                   autocomplete="new-password" placeholder="{{t 'password_ph_6'}}">
          </label>
          <label class="field">
            <span class="field-label">{{t 'phone_label'}} <span class="req">*</span></span>
            <input class="input" type="tel" name="phone" required placeholder="+998 90 123 45 67">
          </label>
        </div>
        <div class="form-actions">
          <button class="btn btn-primary" type="submit">{{t 'add_admin_btn'}}</button>
        </div>
      </form>
    {{/if}}
  </div>

  {{! === Ro'yxat === }}
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">{{t 'existing_admins'}}</h3>
      <span class="badge">{{count}}</span>
    </div>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th class="num">#</th>
            <th>{{t 'login_label'}}</th>
            <th>{{t 'name_field'}}</th>
            <th>{{t 'col_phone'}}</th>
            <th>{{t 'role'}}</th>
            <th>{{t 'col_added'}}</th>
            <th class="actions">{{t 'actions'}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each admins}}
            <tr>
              <td class="num">{{inc @index}}</td>
              <td><code>{{login}}</code></td>
              <td>{{#if name}}{{name}}{{else}}<span class="muted">—</span>{{/if}}</td>
              <td>{{#if phone}}{{phone}}{{else}}<span class="muted">—</span>{{/if}}</td>
              <td>
                {{#if isSuper}}
                  <span class="status-badge status-approved">{{t 'super_admin'}}</span>
                {{else}}
                  <span class="status-badge status-pending">{{t 'admin_role'}}</span>
                {{/if}}
              </td>
              <td class="muted">{{formatDate createdAt}}</td>
              <td class="actions">
                {{#if isSuper}}
                  <span class="muted">—</span>
                {{else}}
                  <form method="POST" action="/admins/{{id}}/delete" style="display:inline"
                        data-confirm="{{t 'admin_delete_confirm'}}">
                    <button type="submit" class="btn btn-sm btn-danger">{{t 'delete'}}</button>
                  </form>
                {{/if}}
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</div>
