<div class="page page-narrow">
  <div class="page-header">
    <div>
      <h2 class="page-title">{{t 'ap_title'}}</h2>
      <p class="page-sub">{{t 'ap_sub'}}</p>
    </div>
  </div>

  {{! === Xabarnomalar === }}
  {{#if (eq query.name_ok "1")}}<div class="alert alert-success">{{t 'ap_name_ok'}}</div>{{/if}}
  {{#if (eq query.cred_ok "1")}}<div class="alert alert-success">{{t 'ap_cred_ok'}}</div>{{/if}}
  {{#if (eq query.cred_error "wrong_current")}}<div class="alert alert-error">{{t 'ap_wrong_current'}}</div>{{/if}}
  {{#if (eq query.cred_error "login_short")}}<div class="alert alert-error">{{t 'ap_login_short'}}</div>{{/if}}
  {{#if (eq query.cred_error "phone_required")}}<div class="alert alert-error">{{t 'ap_phone_required'}}</div>{{/if}}
  {{#if (eq query.cred_error "login_taken")}}<div class="alert alert-error">{{t 'ap_login_taken'}}</div>{{/if}}
  {{#if (eq query.cred_error "unknown")}}<div class="alert alert-error">{{t 'ap_unknown'}}</div>{{/if}}
  {{#if (eq query.cred_error "pass_short")}}<div class="alert alert-error">{{t 'ap_pass_short'}}</div>{{/if}}
  {{#if (eq query.cred_error "pass_mismatch")}}<div class="alert alert-error">{{t 'ap_pass_mismatch'}}</div>{{/if}}
  {{#if (eq query.avatar_ok "1")}}<div class="alert alert-success">{{t 'ap_avatar_ok'}}</div>{{/if}}
  {{#if (eq query.avatar_removed "1")}}<div class="alert alert-success">{{t 'ap_avatar_removed'}}</div>{{/if}}
  {{#if (eq query.avatar_error "invalid_file")}}<div class="alert alert-error">{{t 'ap_avatar_invalid'}}</div>{{/if}}
  {{#if (eq query.avatar_error "processing")}}<div class="alert alert-error">{{t 'ap_avatar_processing'}}</div>{{/if}}

  {{! === Avatar === }}
  <div class="card" style="margin-bottom:16px">
    <div class="card-header"><h3 class="card-title">{{t 'ap_avatar_title'}}</h3></div>
    <div class="form" style="flex-direction:row;align-items:center;gap:24px;flex-wrap:wrap">
      <div>
        {{#if profile.avatar}}
          <img src="{{profile.avatar}}" alt="avatar"
               style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid var(--border)">
        {{else}}
          <div style="width:80px;height:80px;border-radius:50%;background:#eef2ff;display:flex;align-items:center;justify-content:center;font-size:2rem;border:3px solid var(--border)">
            {{#if profile.name}}{{profile.name.[0]}}{{else}}A{{/if}}
          </div>
        {{/if}}
      </div>
      <div style="flex:1;display:flex;flex-direction:column;gap:8px">
        <div style="font-weight:600">{{profile.name}}</div>
        <div style="font-size:13px;color:var(--muted)">{{t 'login_label'}}: <code>{{profile.login}}</code></div>
        <form method="POST" action="/admin/profile/avatar" enctype="multipart/form-data"
              style="display:flex;gap:8px;flex-wrap:wrap">
          <input class="input" type="file" name="avatar" accept="image/jpeg,image/png,image/webp"
                 required style="flex:1;min-width:180px">
          <button class="btn btn-primary" type="submit">{{t 'ap_upload'}}</button>
        </form>
        {{#if profile.avatar}}
        <form method="POST" action="/admin/profile/avatar/remove"
              data-confirm="{{t 'ap_remove_avatar_confirm'}}">
          <button class="btn btn-ghost btn-sm" type="submit">{{t 'ap_remove_image'}}</button>
        </form>
        {{/if}}
        <span class="field-hint">{{t 'ap_avatar_hint'}}</span>
      </div>
    </div>
  </div>

  {{! === Ism === }}
  <div class="card" style="margin-bottom:16px">
    <div class="card-header"><h3 class="card-title">{{t 'ap_name_title'}}</h3></div>
    <form method="POST" action="/admin/profile/name" class="form">
      <label class="field">
        <span class="field-label">{{t 'ap_new_name'}}</span>
        <input class="input" type="text" name="name" value="{{profile.name}}" required minlength="2"
               style="max-width:320px">
      </label>
      <div class="form-actions"><button class="btn btn-primary" type="submit">💾 {{t 'save'}}</button></div>
    </form>
  </div>

  {{! === Login + Parol — BITTA FORMA === }}
  <div class="card" style="margin-bottom:24px">
    <div class="card-header"><h3 class="card-title">{{t 'ap_cred_title'}}</h3></div>
    <form method="POST" action="/admin/profile/credentials" class="form" id="credForm">

      {{! Joriy parol (majburiy tasdiqlash) }}
      <label class="field">
        <span class="field-label">{{t 'ap_current_password'}} <span class="req">*</span></span>
        <div class="pw-wrap">
          <input class="input" type="password" name="currentPassword"
                 id="curPass" required autocomplete="current-password"
                 placeholder="{{t 'ap_current_password_ph'}}">
          <button type="button" class="pw-eye" onclick="togglePw('curPass',this)">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </label>

      <div class="cred-divider">
        <span>{{t 'ap_new_data'}}</span>
      </div>

      {{! Yangi login }}
      <label class="field">
        <span class="field-label">{{t 'ap_new_login'}} <span class="req">*</span></span>
        <input class="input" type="text" name="newLogin"
               value="{{profile.login}}"
               required minlength="3"
               autocomplete="username"
               style="max-width:320px"
               placeholder="{{t 'login_ph_3'}}">
      </label>

      {{! Telefon raqam }}
      <label class="field">
        <span class="field-label">{{t 'phone_label'}} <span class="req">*</span></span>
        <input class="input" type="tel" name="phone"
               value="{{profile.phone}}"
               required
               autocomplete="tel"
               style="max-width:320px"
               placeholder="+998 90 123 45 67">
      </label>

      {{! Yangi parol (ixtiyoriy — bo'sh qolsa o'zgarmaydi) }}
      <label class="field">
        <span class="field-label">
          {{t 'ap_new_password'}}
          <span class="field-hint" style="font-weight:400;margin-left:4px">{{t 'ap_leave_empty'}}</span>
        </span>
        <div class="pw-wrap" style="max-width:360px">
          <input class="input" type="password" name="newPassword"
                 id="newPass" minlength="6"
                 autocomplete="new-password"
                 placeholder="{{t 'password_ph_6'}}"
                 oninput="checkMatch()">
          <button type="button" class="pw-eye" onclick="togglePw('newPass',this)">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </label>

      <label class="field" id="confirmField" style="display:none">
        <span class="field-label">{{t 'ap_repeat_password'}} <span class="req">*</span></span>
        <div class="pw-wrap" style="max-width:360px">
          <input class="input" type="password" name="confirmPassword"
                 id="confPass"
                 autocomplete="new-password"
                 placeholder="{{t 'ap_repeat_ph'}}"
                 oninput="checkMatch()">
          <button type="button" class="pw-eye" onclick="togglePw('confPass',this)">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
        <span id="matchHint" class="field-hint"></span>
      </label>

      <div class="form-actions">
        <button class="btn btn-primary" type="submit" id="credSubmit">💾 {{t 'save'}}</button>
      </div>
    </form>
  </div>
</div>

<style>
.pw-wrap {
  position: relative;
  display: flex;
  align-items: center;
}
.pw-wrap .input { padding-right: 40px; width: 100%; }
.pw-eye {
  position: absolute; right: 10px;
  background: none; border: none; cursor: pointer;
  padding: 0; color: var(--muted); opacity: .5;
  display: flex; align-items: center;
}
.pw-eye:hover { opacity: 1; }

.cred-divider {
  display: flex; align-items: center; gap: 12px;
  color: var(--muted); font-size: 12px; font-weight: 600;
  text-transform: uppercase; letter-spacing: .05em;
  margin: 4px 0;
}
.cred-divider::before, .cred-divider::after {
  content: ''; flex: 1; height: 1px; background: var(--border);
}
</style>

<script>
function togglePw(id, btn) {
  const inp = document.getElementById(id);
  const isText = inp.type === 'text';
  inp.type = isText ? 'password' : 'text';
  btn.style.opacity = isText ? '.5' : '1';
}

// Yangi parol yozilganda "Takrorlang" maydonini ko'rsatish
document.getElementById('newPass').addEventListener('input', function() {
  const cf = document.getElementById('confirmField');
  cf.style.display = this.value ? 'flex' : 'none';
  if (!this.value) {
    document.getElementById('confPass').value = '';
    document.getElementById('matchHint').textContent = '';
    document.getElementById('credSubmit').disabled = false;
  }
});

function checkMatch() {
  const np = document.getElementById('newPass').value;
  const cp = document.getElementById('confPass').value;
  const hint = document.getElementById('matchHint');
  const btn  = document.getElementById('credSubmit');
  if (!cp) { hint.textContent = ''; btn.disabled = false; return; }
  if (np === cp) {
    hint.textContent = '✅ Parollar mos keldi';
    hint.style.color = '#16a34a';
    btn.disabled = false;
  } else {
    hint.textContent = '❌ Parollar mos kelmadi';
    hint.style.color = '#dc2626';
    btn.disabled = true;
  }
}

document.getElementById('credForm').addEventListener('submit', function(e) {
  const np = document.getElementById('newPass').value;
  const cp = document.getElementById('confPass').value;
  if (np && np !== cp) {
    e.preventDefault();
    alert('Yangi parollar mos kelmadi!');
  }
});
</script>
