# ===== Muhit =====
# production / development
NODE_ENV=development
# Server porti (Railway/Vercel o'zi beradi; lokalda 3000)
PORT=3000

# ===== Ma'lumotlar bazasi (PostgreSQL) =====
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=bot_loyiha
# Railway/serverda HTTPS DB ulanishi uchun: true
DB_SSL=false

# ===== Telegram bot =====
# Broadcast va "bonus tasdiqlandi" xabarlarini yuborish uchun MAJBURIY.
# @BotFather → /mybots → API Token. bot_backend bilan BIR XIL token bo'lishi kerak.
BOT_TOKEN=

# ===== Admin autentifikatsiya =====
# Production'da JWT_SECRET MAJBURIY — uzun, tasodifiy qiymat qo'ying.
# Masalan: openssl rand -hex 32
JWT_SECRET=
# Token amal qilish muddati (sekund). Default: 86400 (1 kun)
JWT_TTL=86400

# Admin panelga kirish ma'lumotlari (birinchi ishga tushganda ishlatiladi;
# keyin profil sahifasidan o'zgartirilsa, DB'da saqlanadi)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=12345678
ADMIN_NAME=Administrator
# Avatar URL (ixtiyoriy)
ADMIN_AVATAR=
# Admin telefon raqami (ixtiyoriy; birinchi login'da so'raladi va DB'da saqlanadi)
ADMIN_PHONE=
# Eslatma: yuqoridagi ADMIN_* qiymatlar faqat BIRINCHI ishga tushganda super
# adminni yaratish uchun ishlatiladi. Keyin adminlar DB'da (admins jadvali) saqlanadi.
# Maksimal admin soni "Adminlar" sahifasidan (super admin) belgilanadi.

# ===== Rasm yuklash (ImgBB) =====
# https://api.imgbb.com — mahsulot/avatar rasmlarini yuklash uchun
IMGBB_API_KEY=
